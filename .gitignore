"""
.gitignore - Files to ignore in version control
"""

# Environment variables
.env
.env.local
.env.*.local
config/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*

# Database
*.db
*.sqlite
*.sqlite3
mongo_data/

# Resumes (keep folder, ignore content)
resumes/*.pdf
resumes/*.html

# Cache
.cache/
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak
temp/
tmp/

# Testing
.tox/
.hypothesis/

# Data
data/
*.csv
*.json

# Keys and secrets
*.key
*.pem
secrets/
